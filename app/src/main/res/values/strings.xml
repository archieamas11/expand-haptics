    <!-- Edge Haptics screen (accessibility scroll bounds) -->
    <string name="edge_screen_title">Edge Haptics</string>
    <string name="edge_info_title">Accessibility</string>
    <string name="edge_info_body">Turn on Hapticks accessibility service in Settings → Accessibility. Edge pulses use your chosen pattern and intensity.</string>
    <string name="edge_a11y_scroll_bound_title">Edge Haptics (Accessibility)</string>
    <string name="edge_a11y_scroll_bound_subtitle">Fires a pulse when scrolling hits the top or bottom via accessibility.</string>
    <string name="edge_a11y_guide_title">How it works limits</string>
    <string name="edge_a11y_guide_body">Hapticks detects when you reach the top or bottom edge using scroll position, then plays your edge pattern once.\n\nLimitations: Not all apps support this method which is why there\'s LSPosed for more precise edge detection. The accessibility service must remain on.</string>
    <string name="edge_lsposed_title">Advanced Edge Haptics (LSPosed)</string>
    <string name="edge_lsposed_subtitle">System wide solution with more precise edge detection.</string>
    <string name="edge_lsposed_what_title">What this does</string>
    <string name="edge_lsposed_what_body">Switches to LSPosed-based edge detection, hooking overscroll at system level for a cleaner pulse without duplicates. Follow steps below only if using LSPosed.</string>
    <string name="edge_lsposed_setup_title">How to set up</string>
    <string name="edge_lsposed_setup_body">Enable in LSPosed Manager: 
\n1. Open LSPosed.
\n2. Enable the Hapticks module.
\n3. Choose target apps in module scope.
\n4. Restart those apps or your phone.</string>
    <string name="edge_lsposed_status_active">Active</string>
    <string name="edge_lsposed_status_inactive">Not active</string>
